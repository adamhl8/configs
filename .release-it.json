{
  "$schema": "https://unpkg.com/release-it/schema/release-it.json",
  "git": {
    "commitMessage": "release: v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "version ${version}"
  },
  "hooks": {
    "before:init": "nub run bundle"
  },
  "github": {
    "release": true,
    "releaseName": "${version}"
  },
  "npm": {
    "publishPackageManager": "nub",
    "publishPath": ""
  }
}
