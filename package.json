{
  "name": "@adamhl8/configs",
  "version": "0.23.0",
  "homepage": "https://github.com/adamhl8/configs",
  "bugs": {
    "url": "https://github.com/adamhl8/configs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhl8/configs.git"
  },
  "bin": {
    "adamhl8-cliff": "./dist/adamhl8-cliff/index",
    "adamhl8-knip": "./dist/adamhl8-knip/index"
  },
  "files": [
    "./dist/"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    "./tsconfig": "./dist/configs/tsconfig.base.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "lint": "markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && oxfmt && oxlint --fix --fix-suggestions --fix-dangerously && adamhl8-knip",
    "bump-deps": "nub update -L && rm -f lock.yaml && nub i && oxfmt",
    "bundle": "nub run lint && tsdown",
    "release": "release-it --ci -i \"$(adamhl8-cliff --bumped-version)\"",
    "prepare": "lefthook install && nub ./patch-knip.ts && tsdown"
  },
  "dependencies": {
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "es-toolkit": "^1.49.0",
    "type-fest": "^5.7.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.4",
    "@commitlint/cli": "^21.1.0",
    "@types/node": "^26.0.1",
    "knip": "^6.23.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "publint": "^0.3.21",
    "release-it": "^20.2.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
