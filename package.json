{
  "name": "@adamhl8/configs",
  "version": "1.2.1",
  "description": "My shared configs for TS projects",
  "homepage": "https://github.com/adamhl8/configs",
  "bugs": {
    "url": "https://github.com/adamhl8/configs/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adam Langbert",
    "email": "adamhl@pm.me",
    "url": "https://github.com/adamhl8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhl8/configs.git"
  },
  "bin": {
    "adamhl8-bunfig": "./dist/adamhl8-bunfig/index",
    "adamhl8-cliff": "./dist/adamhl8-cliff/index",
    "adamhl8-gitignore": "./dist/adamhl8-gitignore/index"
  },
  "files": [
    "./dist/"
  ],
  "type": "module",
  "imports": {
    "#*": "./src/*"
  },
  "exports": {
    "./tsconfig": "./dist/configs/tsconfig.base.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "import": "./dist/env/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "just prepare"
  },
  "dependencies": {
    "@adamhl8/eslint-plugin-clean-modules": "^0.1.4",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "arkenv": "^0.12.2",
    "arktype": "^2.2.3",
    "es-toolkit": "^1.49.0",
    "smol-toml": "^1.7.0",
    "ts-explicit-errors": "^4.1.2",
    "ts-extras": "^1.2.0",
    "type-fest": "^5.8.0"
  },
  "devDependencies": {
    "@adamhl8/configs": "file:.",
    "@arethetypeswrong/core": "^0.18.5",
    "@commitlint/cli": "^21.2.1",
    "@types/bun": "^1.3.14",
    "knip": "^6.26.0",
    "markdown-toc": "^1.2.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "release-it": "^20.2.1",
    "tsdown": "^0.22.5",
    "typescript": "^7.0.2"
  },
  "peerDependencies": {
    "@arethetypeswrong/core": ">=0.18",
    "@commitlint/cli": ">=21",
    "@commitlint/config-conventional": ">=21",
    "knip": ">=6",
    "markdown-toc": ">=1",
    "oxfmt": ">=0.50",
    "oxlint": ">=1",
    "oxlint-tsgolint": ">=0.24",
    "publint": ">=0.3",
    "release-it": ">=19",
    "tsdown": ">=0.20",
    "typescript": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@arethetypeswrong/core": {
      "optional": true
    },
    "@commitlint/cli": {
      "optional": true
    },
    "@commitlint/config-conventional": {
      "optional": true
    },
    "knip": {
      "optional": true
    },
    "markdown-toc": {
      "optional": true
    },
    "oxfmt": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    },
    "oxlint": {
      "optional": true
    },
    "publint": {
      "optional": true
    },
    "release-it": {
      "optional": true
    },
    "tsdown": {
      "optional": true
    }
  }
}
