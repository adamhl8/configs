{
  "name": "@adamhl8/configs",
  "version": "0.19.3",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamhl8/configs.git"
  },
  "homepage": "https://github.com/adamhl8/configs",
  "bugs": {
    "url": "https://github.com/adamhl8/configs/issues"
  },
  "author": {
    "email": "adamhl@pm.me",
    "name": "Adam Langbert",
    "url": "https://github.com/adamhl8"
  },
  "license": "MIT",
  "bin": {
    "adamhl8-knip": "./dist/adamhl8-knip/index"
  },
  "exports": {
    "./tsconfig": "./dist/configs/tsconfig.base.json",
    "./biome": "./dist/configs/biome.base.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["./dist/"],
  "scripts": {
    "bundle": "bun lint && tsdown",
    "lint": "bun ./generate-biome-rules.ts && markdown-toc -i --bullets '-' --maxdepth 3 ./README.md && tsc --noEmit && biome check --write && ./src/adamhl8-knip/index.ts",
    "prepare": "find .githooks -type f -exec ln -srf {} .git/hooks/ \\; || true",
    "prepublishOnly": "bun bundle",
    "postinstall": "bun ./patch-knip.ts"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "es-toolkit": "^1.46.0",
    "remeda": "^2.33.7",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "knip": "^6.7.0",
    "markdown-toc": "^1.2.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
